{
  "name": "novelic",
  "version": "0.1.0",
  "description": "Novel timeline visualization desktop app",
  "main": "dist/main/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "concurrently -k \"vite --config vite.renderer.config.ts\" \"vite build --watch --config vite.main.config.ts\" \"vite build --watch --config vite.preload.config.ts\" \"wait-on dist/main/main.js dist/preload/preload.js tcp:5173 && ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "start": "electron .",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "moment": "^2.30.1",
    "react": "^18.3.1",
    "react-big-calendar": "^1.15.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.20",
    "@types/react-big-calendar": "^1.16.1",
    "@types/react-dom": "^18.3.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.novelic.app",
    "productName": "Novelic",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
