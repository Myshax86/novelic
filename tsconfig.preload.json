{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "electron"],
    "outDir": "dist/preload"
  },
  "include": ["src/preload/**/*.ts", "src/shared/**/*.ts"]
}
